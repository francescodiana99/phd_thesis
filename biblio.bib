@misc{carlettiGUIDEEnhancingGradient2025,
  title = {{{GUIDE}}: {{Enhancing Gradient Inversion Attacks}} in {{Federated Learning}} with {{Denoising Models}}},
  shorttitle = {{{GUIDE}}},
  author = {Carletti, Vincenzo and Foggia, Pasquale and Mazzocca, Carlo and Parrella, Giuseppe and Vento, Mario},
  year = 2025,
