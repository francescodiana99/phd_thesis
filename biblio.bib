@article{renGRNNGenerativeRegression2022a,
  title = {{{GRNN}}: {{Generative Regression Neural Network}}---{{A Data Leakage Attack}} for {{Federated Learning}}},
  shorttitle = {{{GRNN}}},
  author = {Ren, Hanchi and Deng, Jingjing and Xie, Xianghua},
