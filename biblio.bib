@article{Yin_defense_taxonomy,
author = {Yin, Xuefei and Zhu, Yanming and Hu, Jiankun},
title = {A Comprehensive Survey of Privacy-preserving Federated Learning: A Taxonomy, Review, and Future Directions},
year = {2021},
